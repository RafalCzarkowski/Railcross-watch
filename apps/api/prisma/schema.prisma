datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  SUPERADMIN
  ADMIN
  USER
}

enum ApprovalStatus {
  PENDING
  APPROVED
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  passwordHash   String?
  name           String?
  avatarUrl      String?
  role           UserRole       @default(USER)
  approvalStatus ApprovalStatus @default(PENDING)
  approvedAt     DateTime?
  blockedAt      DateTime?
  mfaEnabled     Boolean        @default(false)
  mfaSecret      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  accounts       Account[]
  videos         CrossingVideo[]
  logs           ActivityLog[]
}

model CrossingVideo {
  id             String   @id @default(cuid())
  sourceType     String   @default("FILE")
  filename       String?
  originalName   String?
  mimetype       String?
  size           Int?
  path           String?
  sourceUrl      String?
  title          String?
  description    String?
  location       String?
  analysisStatus String   @default("PENDING")
  approvalStatus String   @default("PENDING")
  uploadedById   String
  uploadedBy     User     @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  actorId    String?
  actor      User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  targetId   String?
  targetType String?
  message    String
  createdAt  DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}
